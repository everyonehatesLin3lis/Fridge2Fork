GEMMA_API_KEY=your_api_key_here
GEMMA_MODEL_NAME=gemma4:e4b
APP_MODE=local
OLLAMA_BASE_URL=http://localhost:11434
# Local model calls (especially image detection) can take 60s+ per photo.
OLLAMA_TIMEOUT_SECONDS=300
# Photo analysis model. gemma4:e4b's Ollama vision path can return "no image",
# so a dedicated vision model is used for photos by default.
VISION_MODEL_NAME=llava:7b

# Optional local Google AI mode using an API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_api_key_here
GOOGLE_MODEL_NAME=gemini-3.5-flash

# Keyless Google Cloud Run/Vertex AI mode. Cloud Run supplies credentials from
# its service account; GOOGLE_CLOUD_PROJECT is injected during deployment.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
